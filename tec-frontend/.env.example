# =============================================================================
# TEC App — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Keep server-only secrets (PI_API_KEY, etc.) out of NEXT_PUBLIC_ variables.
# =============================================================================

# ---- Pi Network: App Identity ------------------------------------------------

# Pi App ID from the Pi Developer Portal (https://developers.minepi.com)
# Used server-side only.
PI_APP_ID=your_pi_app_id_here

# Client-side Pi App ID (required for Pi.init() in the browser).
# This value is embedded in the build output — only put non-secret IDs here.
NEXT_PUBLIC_PI_APP_ID=your_pi_app_id_here

# ---- Pi Network: Sandbox vs Mainnet ------------------------------------------

# Server-side sandbox flag.
#   true  → Sandbox / Testnet  (safe for development, no real Pi)
#   false → Mainnet / Production  (real Pi transactions)
PI_SANDBOX=true

# Client-side sandbox flag (controls Pi.init() sandbox parameter).
#   true  → Sandbox / Testnet
#   false → Mainnet / Production
NEXT_PUBLIC_PI_SANDBOX=true

# ---- Pi SDK Timeouts (optional, in milliseconds) -----------------------------

# Maximum time to wait for the Pi SDK script to load before giving up.
# Default: 25000 (25 s). Increase on slow networks (max: 120000 / 2 min).
# NEXT_PUBLIC_PI_SDK_TIMEOUT=25000

# Maximum time to wait for Pi.authenticate() to resolve.
# Default: 45000 (45 s). Increase if authentication frequently times out.
# NEXT_PUBLIC_PI_AUTH_TIMEOUT=45000

# Maximum time to wait for the server payment approval step.
# Default: 180000 (3 min).
# NEXT_PUBLIC_PI_APPROVAL_TIMEOUT=180000

# Maximum time to wait for the server payment completion step.
# Default: 180000 (3 min).
# NEXT_PUBLIC_PI_COMPLETION_TIMEOUT=180000

# ---- Backend / API Gateway ---------------------------------------------------

# Base URL for the TEC API Gateway (routes payment calls to the Core Backend).
# Do NOT expose your internal service URLs publicly if avoidable.
NEXT_PUBLIC_API_GATEWAY_URL=https://your-api-gateway-url-here

