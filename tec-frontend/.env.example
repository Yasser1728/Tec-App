# =============================================================================
# TEC App — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
#
# SECURITY NOTE — NEXT_PUBLIC_* variables:
#   Any variable prefixed with NEXT_PUBLIC_ is inlined into the browser
#   JavaScript bundle at build time.  NEVER put secrets (API keys, tokens,
#   private keys) in NEXT_PUBLIC_* variables.
#   Server-only variables (no NEXT_PUBLIC_ prefix) stay on the server and
#   are never sent to the browser.
# =============================================================================

# ---- Pi Network: App Identity ------------------------------------------------

# Pi App ID — server-side only (e.g. for server-to-server API calls).
# Not exposed to the browser.
PI_APP_ID=tec-app-de161fa2243c797b

# Pi App ID — required by Pi.init() which runs in the browser.
# This is a non-secret identifier, safe to expose in the bundle.
NEXT_PUBLIC_PI_APP_ID=tec-app-de161fa2243c797b

# Pi Sandbox App URL (for reference / deep-linking from Pi Portal)
NEXT_PUBLIC_PI_APP_URL=https://sandbox.minepi.com/app/tec-app-de161fa2243c797b

# ---- Pi Network: Sandbox vs Mainnet ------------------------------------------
#
#  SANDBOX (development & QA)
#    - No real Pi is transferred.
#    - Uses Pi Developer Sandbox environment.
#    - Safe to use during development and testing.
#    → Set both PI_SANDBOX and NEXT_PUBLIC_PI_SANDBOX to "true"
#
#  MAINNET / PRODUCTION
#    - Real Pi transactions occur.
#    - Requires a live Pi Developer Portal app with Mainnet access.
#    - Double-check all payment amounts and approval logic before enabling.
#    → Set both PI_SANDBOX and NEXT_PUBLIC_PI_SANDBOX to "false"
#
# Server-side sandbox flag (used by the backend payment service).
PI_SANDBOX=true

# Client-side sandbox flag (passed to Pi.init() in the browser).
# Must match PI_SANDBOX to avoid mismatched environments.
NEXT_PUBLIC_PI_SANDBOX=true

# ---- Pi SDK Timeouts (optional, milliseconds) --------------------------------
#
# These are build-time constants baked into the client bundle.
# Increase them on slow networks; do not exceed 120000 (2 min).

# Maximum time to wait for the Pi SDK script to load before giving up.
# Default: 25000 (25 s). For slow networks, consider increasing to 35000 (35 s).
# NEXT_PUBLIC_PI_SDK_TIMEOUT=35000

# Maximum time to wait for Pi.authenticate() to resolve.
# Default: 45000 (45 s). Increase if authentication frequently times out.
# NEXT_PUBLIC_PI_AUTH_TIMEOUT=45000

# Maximum time to wait for the server payment approval step.
# Default: 180000 (3 min).
# NEXT_PUBLIC_PI_APPROVAL_TIMEOUT=180000

# Maximum time to wait for the server payment completion step.
# Default: 180000 (3 min).
# NEXT_PUBLIC_PI_COMPLETION_TIMEOUT=180000

# ---- Backend / API Gateway ---------------------------------------------------
#
# Base URL for the TEC API Gateway (proxies payment/auth calls to microservices).
# This URL is sent to the browser so it can call the gateway directly.
# Use a public-facing URL only — never expose internal service hostnames here.
# If you want to keep the gateway URL private, proxy it through a Next.js
# API route (/app/api/*) and remove the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_API_GATEWAY_URL=https://api-gateway-production-6a68.up.railway.app

