{
  "name": "tec-platform",
  "version": "1.0.0",
  "description": "TEC Ecosystem - 24 App Digital Platform",
  "private": true,
  "scripts": {
    "dev": "npm run dev --workspace=tec-frontend",
    "build": "npm run build --workspace=tec-frontend",
    "typecheck": "npm run typecheck --workspace=tec-frontend",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "prepare": "husky",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "husky": "^9.1.7",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "glob": "^13.0.0",
    "test-exclude": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "tec-frontend",
    "packages/*"
  ]
}
