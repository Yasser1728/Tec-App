# Environment Configuration for TEC Frontend (Vercel / Next.js)
# Copy this file to tec-frontend/.env.local and fill in the values.
# The backend services have been removed; all API calls go to the external gateway.

# ===== FRONTEND (NEXT_PUBLIC_*) VARIABLES =====
# These are inlined into the browser bundle at build time.
# NEVER put secrets in NEXT_PUBLIC_* variables.

# External API Gateway URL (replace with your deployed gateway URL)
NEXT_PUBLIC_API_GATEWAY_URL=https://api-gateway-production-6a68.up.railway.app

# Pi App ID — required by Pi.init() (non-secret identifier, get from Pi Developer Portal)
NEXT_PUBLIC_PI_APP_ID=tec-app-de161fa2243c797b

# Pi Sandbox App URL (for reference / deep-linking from Pi Portal)
NEXT_PUBLIC_PI_APP_URL=https://sandbox.minepi.com/app/tec-app-de161fa2243c797b

# Pi Network environment: 'true' for Testnet/Sandbox, 'false' for Mainnet/Production
NEXT_PUBLIC_PI_SANDBOX=true

# ===== INSTRUCTIONS =====
# 1. Copy this file: cp .env.example tec-frontend/.env.local
# 2. Fill in NEXT_PUBLIC_API_GATEWAY_URL with your deployed gateway URL
# 3. Run: cd tec-frontend && npm run dev
